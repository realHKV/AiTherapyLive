# ─── AI Therapy Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# Database (PostgreSQL — Neon)
# Neon connection string format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/therapyai
DATABASE_USER=therapyai_user
DATABASE_PASSWORD=your_strong_password_here

# Redis (Upstash)
# Find these in Upstash console → your Redis db → Connection details
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_redis_password
REDIS_SSL=true   # Must be true for Upstash

# JWT (RSA key pair)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 -w 0   -> JWT_PRIVATE_KEY
#   cat public.pem  | base64 -w 0   -> JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Encryption
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=

# AI Provider (Free Tier - Groq Llama)
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.1-8b-instant

# AI Provider (Pro Tier - OpenAI 4o-mini)
# If Pro tier keys are omitted, the app perfectly delegates and mirrors back to the Free Tier Groq configuration automatically.
# AI_PRO_BASE_URL=https://api.openai.com/v1
# AI_PRO_API_KEY=your_openai_api_key_here
# AI_PRO_MODEL=gpt-4o-mini

# OAuth2 (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS — set to your deployed frontend URL (no trailing slash)
CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app

# Razorpay (payment processing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App flags — NEVER set to true in production
DEV_MODE=false

